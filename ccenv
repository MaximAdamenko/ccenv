def _ensure_agent_memory(cfg: Config, name: str) -> Path:
    """Create Memory_Logs/ for *name* if it doesn't already exist."""
    mem_dir = cfg.agent_memory_dir(name)
    mem_dir.mkdir(parents=True, exist_ok=True)
    (mem_dir / "Sessions").mkdir(exist_ok=True)
    (mem_dir / "Notes").mkdir(exist_ok=True)
    (mem_dir / "Archive").mkdir(exist_ok=True)

    today = datetime.date.today().isoformat()
    scaffolds = {
        "Context.md":    _CONTEXT_TEMPLATE.format(agent=name, date=today),
        "Checkpoint.md": _CHECKPOINT_TEMPLATE.format(agent=name),
        "Lessons.md":    _LESSONS_TEMPLATE.format(agent=name),
        "Preferences.md":_PREFERENCES_TEMPLATE.format(agent=name),
    }
    for fname, content in scaffolds.items():
        target = mem_dir / fname
        if not target.exists():
            target.write_text(content, encoding="utf-8")

    return mem_dir


def _append_session(mem_dir: Path, agent: str, summary: str) -> Path:
    """Append a session entry to Sessions/Session_YYYY-MM-DD.md."""
    today = datetime.date.today().isoformat()
    session_file = mem_dir / "Sessions" / f"Session_{today}.md"
    header = f"# Session — {today}\n\n**Agent:** {agent}\n\n---\n\n"
    entry  = f"## Entry\n{summary}\n\n---\n"
    if session_file.exists():
        with session_file.open("a", encoding="utf-8") as f:
            f.write(entry)
    else:
        session_file.write_text(header + entry, encoding="utf-8")
    return session_file


def cmd_memory_init(cfg: Config, name: str) -> int:
    """Scaffold Memory_Logs/ for agent *name*."""
    mem_dir = _ensure_agent_memory(cfg, name)
    print(f"Memory initialized for agent '{name}' at {mem_dir}")
    return 0


def cmd_memory_log(cfg: Config, name: str, summary: str) -> int:
    """Append a session log entry to agent *name*'s Sessions/."""
    mem_dir = _ensure_agent_memory(cfg, name)
    sf = _append_session(mem_dir, name, summary)
    print(f"Logged session for '{name}' → {sf}")
    return 0


def cmd_memory_show(cfg: Config, name: str) -> int:
    """Print the Context.md of agent *name*."""
    mem_dir = cfg.agent_memory_dir(name)
    ctx = mem_dir / "Context.md"
    if not ctx.is_file():
        print(f"No memory found for agent '{name}'. Run: ccenv memory init {name}",
              file=sys.stderr)
        return 1
    print(ctx.read_text(encoding="utf-8"))
    return 0


def cmd_memory_list(cfg: Config) -> int:
    """List all agents that have initialised memory."""
    agents_dir = cfg.agents_dir
    if not agents_dir.is_dir():
        print("No agents with memory yet. Run: ccenv memory init <agent>")
        return 0
    agents = sorted(p.name for p in agents_dir.iterdir() if p.is_dir())
    if not agents:
        print("No agents with memory yet.")
    else:
        print("Agents with isolated memory:")
        for a in agents:
            print(f"  {a}  →  {cfg.agent_memory_dir(a)}")
    return 0


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def cmd_init(cfg: Config) -> int:
    """Create ~/.ccenv/{profiles,.env,state.json} and an example profile."""
    cfg.ccenv_dir.mkdir(parents=True, exist_ok=True)
    cfg.profiles_dir.mkdir(parents=True, exist_ok=True)

    if not cfg.secrets_file.exists():
        cfg.secrets_file.write_text(
            "# Local secrets for ccenv — DO NOT commit this file.\n"
            "# Profile mcp.json templates reference these by name, e.g. {{ MY_TOKEN }}.\n"
            "CLAUDE_API_KEY=sk_xxxxxxxxxxxxxxxxxxxx\n"
            "GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx\n"
            "JENKINS_TOKEN=jnkns_xxxxxxxxxxxxxxxxx\n"
            "FIGMA_API_KEY=figd_xxxxxxxxxxxxxxxxxxx\n",
            encoding="utf-8",
        )
        try:
            os.chmod(cfg.secrets_file, 0o600)
        except OSError:
            pass

    if not cfg.state_file.exists():
        _write_state(cfg.state_file, None)

    cfg.agents_dir.mkdir(parents=True, exist_ok=True)

    # Seed Brief.md shared dashboard
    if not cfg.brief_file.exists():
        cfg.brief_file.write_text(
            "# Brief — ccenv Project Dashboard\n\n"
            "| Date | Agent | Activity |\n"
            "| ---- | ----- | -------- |\n",
            encoding="utf-8",
        )

    example = cfg.profiles_dir / "example"
    if not example.exists():
        (example / "skills" / "hello-skill").mkdir(parents=True)
        (example / "profile.yaml").write_text(
            "name: example\n"
            "description: Minimal example profile created by `ccenv init`.\n"
            "instructions: CLAUDE.md\n"
            "mcp_template: mcp.json\n"
            "skills:\n"
            "  - skills/hello-skill\n",
            encoding="utf-8",
        )
        (example / "CLAUDE.md").write_text(
            "# Example profile\n\nThis is the example profile. Replace it.\n",
            encoding="utf-8",
        )
        (example / "mcp.json").write_text(
            json.dumps({"mcpServers": {}}, indent=2) + "\n",
            encoding="utf-8",
        )
        (example / "skills" / "hello-skill" / "SKILL.md").write_text(
            "---\nname: hello-skill\ndescription: Placeholder skill.\n---\n\n"
            "# hello-skill\n\nReplace me.\n",
            encoding="utf-8",
        )

    print(f"Initialized ccenv at {cfg.ccenv_dir}")
    print(f"  profiles dir:  {cfg.profiles_dir}")
    print(f"  secrets file:  {cfg.secrets_file}")
    print(f"  state file:    {cfg.state_file}")
    print("Try:  ccenv apply example")
    return 0


def cmd_apply(cfg: Config, name: str, chat: bool = False) -> int:
    """Apply *name* profile to ~/.claude/."""
    profile_dir = _resolve_profile(cfg, name)
    manifest    = _load_manifest(profile_dir)
    instructions_path, mcp_path, skills = _resolve_profile_paths(profile_dir, manifest)

    secrets      = _load_env_secrets(cfg.secrets_file)
    mcp_rendered = _render_mcp(mcp_path, secrets)

    skill_count = _write_profile(cfg.claude_dir, instructions_path, mcp_rendered, profile_dir, skills)
    _write_state(cfg.state_file, name)
    
    # Ensure agent memory is initialized
    _ensure_agent_memory(cfg, name)

    print(f"Applied profile '{name}' to {cfg.claude_dir}")
    print(f"  CLAUDE.md  <- {instructions_path}")
    print(f"  mcp.json   <- {mcp_path} (rendered)")
    print(f"  skills/    <- {skill_count} skill(s)")
    print(f"  memory/    <- {cfg.agent_memory_dir(name)}")

    if chat:
        return cmd_chat(cfg)

    return 0


def cmd_switch(cfg: Config, name: str, chat: bool = False) -> int:
    """Switch to *name* profile, logging the previous → next transition."""
    state   = _read_state(cfg.state_file)
    current = state.get("active_profile")
    if current == name:
        print(f"Profile '{name}' is already active. Re-applying.")
    else:
        print(f"Switching from '{current or '<none>'}' to '{name}'.")
    return cmd_apply(cfg, name, chat=chat)

    """Switch to *name* profile, logging the previous → next transition."""
    state   = _read_state(cfg.state_file)
    current = state.get("active_profile")
    if current == name:
        print(f"Profile '{name}' is already active. Re-applying.")
    else:
        print(f"Switching from '{current or '<none>'}' to '{name}'.")
    return cmd_apply(cfg, name)


def cmd_chat(cfg: Config) -> int:
    """Start an interactive chat session with Claude as the active agent."""
    if not ANTHROPIC_AVAILABLE:
        print("anthropic library not installed. Run: pip install -r requirements.txt",
              file=sys.stderr)
        return 1
    
    state = _read_state(cfg.state_file)
    active = state.get("active_profile")
    
    if active is None:
        print("No profile is active. Run: ccenv apply <profile>", file=sys.stderr)
        return 1
    
    profile_dir = _resolve_profile(cfg, active)
    manifest    = _load_manifest(profile_dir)
    instructions_path, _, _ = _resolve_profile_paths(profile_dir, manifest)
    
    instructions = instructions_path.read_text(encoding="utf-8")
    mem_dir = cfg.agent_memory_dir(active)
    
    # Load memory context
    context_file = mem_dir / "Context.md"
    context_text = context_file.read_text(encoding="utf-8") if context_file.is_file() else "[No context yet]"
    
    # Get API key
    secrets = _load_env_secrets(cfg.secrets_file)
    api_key = secrets.get("CLAUDE_API_KEY")
    
    if not api_key:
        print("CLAUDE_API_KEY not found in ~/.ccenv/.env", file=sys.stderr)
        return 1
    
    # Build system prompt
    system_prompt = f"""{instructions}

---

## Your Memory (Persistent Across Sessions)

{context_text}

---

## Instructions for This Session
- You are this agent. Embody their expertise and personality.
- Reference your memory when relevant.
- Log important lessons back via "ccenv memory log <agent>"
- When done, type 'exit' or 'quit' to end the chat.
"""
    
    print(f"\n{'='*70}")
    print(f"Agent: {active.upper()}")
    print(f"Claude API: Connected ✓")
    print(f"Memory: {mem_dir}")
    print(f"{'='*70}\n")
    
    client = Anthropic(api_key=api_key)
    conversation_history = []
    
    print("Chat Mode (type 'exit' or 'quit' to end session)\n")
    
    while True:
        try:
            user_input = input(f"{active}> ").strip()
        except EOFError:
            break
        
        if user_input.lower() in ("exit", "quit", "bye"):
            break
        
        if not user_input:
            continue
        
        # Add user message to history
        conversation_history.append({
            "role": "user",
            "content": user_input
        })
        
        # Call Claude API
        try:
            response = client.messages.create(
                model="claude-3-5-sonnet-20241022",
                max_tokens=2048,
                system=system_prompt,
                messages=conversation_history
            )
            
            assistant_message = response.content[0].text
            
            # Add assistant response to history
            conversation_history.append({
                "role": "assistant",
                "content": assistant_message
            })
            
            print(f"\n{assistant_message}\n")
        
        except Exception as e:
            print(f"\n✗ Error calling Claude API: {e}\n", file=sys.stderr)
            # Remove the failed user message from history
            conversation_history.pop()
    
    # Log the session
    if conversation_history:
        session_content = "## Conversation\n\n"
        for msg in conversation_history:
            role = msg["role"].capitalize()
            session_content += f"\n**{role}:**\n{msg['content']}\n"
        
        _append_session(mem_dir, active, session_content)
        print(f"\n✓ Session logged to {mem_dir}/Sessions/")
    
    return 0


def cmd_status(cfg: Config) -> int:
    """Print the active profile and list all available profiles."""
    state  = _read_state(cfg.state_file)
    active = state.get("active_profile")
    if active is None:
        print("No profile is active. Run `ccenv apply <profile>`.")
    else:
        print(f"Active profile: {active}")

    if cfg.profiles_dir.is_dir():
        names = sorted(p.name for p in cfg.profiles_dir.iterdir() if p.is_dir())
        if names:
            print("Available profiles: " + ", ".join(names))
    return 0


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="ccenv",
        description="Claude Code environment manager with per-agent memory isolation.",
    )
    parser.add_argument(
        "--home",
        type=Path,
        default=None,
        help="Override $HOME (used by the test suite).",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("init",   help="Create the ccenv working directory.")
    p_apply = sub.add_parser("apply",  help="Apply a profile to ~/.claude/.")
    p_apply.add_argument("profile")
    p_apply.add_argument("--chat", action="store_true", help="Launch chat immediately after applying the profile.")
    p_switch = sub.add_parser("switch", help="Switch to a different profile.")
    p_switch.add_argument("profile")
    p_switch.add_argument("--chat", action="store_true", help="Launch chat immediately after switching profiles.")
    sub.add_parser("status", help="Show the active profile.")
    sub.add_parser("chat",   help="Start interactive chat with active agent.")

    # Memory management subcommands
    p_memory = sub.add_parser("memory", help="Agent memory management.")
    memory_sub = p_memory.add_subparsers(dest="memory_command", required=True)
    
    p_mem_init = memory_sub.add_parser("init", help="Initialize Memory_Logs for an agent.")
    p_mem_init.add_argument("agent")
    
    p_mem_log = memory_sub.add_parser("log", help="Log a session entry for an agent.")
    p_mem_log.add_argument("agent")
    p_mem_log.add_argument("summary")
    
    p_mem_show = memory_sub.add_parser("show", help="Show Context.md for an agent.")
    p_mem_show.add_argument("agent")
    
    memory_sub.add_parser("list", help="List all agents with initialized memory.")

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args   = parser.parse_args(argv)
    home   = args.home if args.home is not None else Path(os.path.expanduser("~"))
    cfg    = Config(home=Path(home).expanduser())

    try:
        if args.command == "init":
            return cmd_init(cfg)
        if args.command == "apply":
            return cmd_apply(cfg, args.profile, chat=args.chat)
        if args.command == "switch":
            return cmd_switch(cfg, args.profile, chat=args.chat)
        if args.command == "status":
            return cmd_status(cfg)
        if args.command == "chat":
            return cmd_chat(cfg)
        if args.command == "memory":
            if args.memory_command == "init":
                return cmd_memory_init(cfg, args.agent)
            if args.memory_command == "log":
                return cmd_memory_log(cfg, args.agent, args.summary)
            if args.memory_command == "show":
                return cmd_memory_show(cfg, args.agent)
            if args.memory_command == "list":
                return cmd_memory_list(cfg)
    except CcenvError as exc:
        print(f"ccenv: error: {exc}", file=sys.stderr)
        return 1

    parser.print_help()
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
